# Anthropic API key for Claude-powered AI prediction.
# Required only if you want to use the AI predictor. The rule-based engine
# and backtester work without it.
# ANTHROPIC_API_KEY=$(cat ~/.anthropic_api_key)
ANTHROPIC_API_KEY=sk-ant-...

# Alpaca API keys for live/paper trading via AlpacaBroker.
# Paper trading base URL: https://paper-api.alpaca.markets
# Live trading base URL:  https://api.alpaca.markets
ALPACA_API_KEY=PKXXXXXXXXXXXXXXXXXXXXXXXX
ALPACA_API_SECRET=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Optional: override the config directory path (default: <repo-root>/config/)
# PREDICTION_TRADING_CONFIG_DIR=/abs/path/to/config

# Optional: override the config file path directly (default: <repo-root>/config/default.yaml)
# PREDICTION_TRADING_CONFIG=/abs/path/to/default.yaml
