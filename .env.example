# Anthropic API key for Claude-powered AI prediction.
# Required only if you want to use the AI predictor. The rule-based engine
# and backtester work without it.
# ANTHROPIC_API_KEY=$(cat ~/.anthropic_api_key)
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override default Claude model (see README for supported IDs).
# CLAUDE_MODEL=claude-sonnet-4-6
